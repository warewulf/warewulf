{{- $host := .BuildHost }}
{{- $time := .BuildTime }}
{{- $source := .BuildSource }}
{{range $devname, $netdev := .ThisNode.NetDevs -}}
{{- $filename := print $devname  }}
{{- file $filename }}
# This file is autogenerated by warewulf
network:
  version: 2
  renderer: networkd
  ethernets:
	{{$netdev.Device.Get}}:
  	addresses:
    	- {{$netdev.Ipaddr.Get}}/{{$netdev.Netmask.Get}}
	{{ if $netdev.MTU.Get -}}
	mtu: {{$netdev.MTU.Get}}
	{{- end}}
{{- end}}
